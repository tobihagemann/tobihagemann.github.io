---
import BaseLayout from '../layouts/BaseLayout.astro';
import { permalink } from '../lib/permalink';
import { getExcerpt } from '../lib/excerpt';
import { getSortedPosts } from '../lib/posts';
import { formatDate } from '../lib/date';
import { site } from '../data/site';

const posts = (await getSortedPosts()).slice(0, 3);
const cards = posts.map((post) => ({
  title: post.data.title,
  date: formatDate(post.data.date),
  url: permalink(post.id),
  excerpt: getExcerpt(post, 100),
}));
---
<BaseLayout>
  <div id="home" class="flex w-full flex-col text-center">
    <div class="mx-4 my-6 sm:my-12">
      <img class="img-fluid rounded-circle shadow mx-auto" src="https://s.gravatar.com/avatar/c3c0759120c7bcd0117d237cb356cd6e?s=200" srcset="https://s.gravatar.com/avatar/c3c0759120c7bcd0117d237cb356cd6e?s=400 2x" alt="Profile Image" />
    </div>
    <div class="headings px-4 pb-6 sm:pb-12">
      <h1>{site.name}</h1>
      <h2>Developer &amp; Designer</h2>
      <h3>Based in Bonn, Germany</h3>
    </div>
  </div>

  <div class="container my-6 sm:my-12">
    <div class="grid grid-cols-1 gap-[30px] sm:grid-cols-3">
{ cards.map((card) => (
      <div class="card h-full shadow-sm">
        <div class="card-body flex flex-col">
          <h4 class="card-title mb-1 truncate">{card.title}</h4>
          <p class="small text-muted mb-2">{card.date}</p>
          <p class="card-text">{card.excerpt}</p>
          <a href={card.url} class="mt-auto">Continue reading <span class="sr-only">{card.title}</span></a>
        </div>
      </div>
)) }
    </div>
  </div>
</BaseLayout>
