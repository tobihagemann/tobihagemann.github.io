---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/date';

interface Props {
  title: string;
  date: Date;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, date, description, ogImage, noindex } = Astro.props;
const formattedDate = formatDate(date);
---
<BaseLayout
  {title}
  {description}
  ogType="article"
  {ogImage}
  publishedTime={formattedDate}
  {noindex}
  activelink="/blog/"
>
  <div class="container">
    <header class="mt-6 mb-4 border-b sm:mt-12">
      <h1 class="mb-1">{title}</h1>
      <p class="text-muted">{formattedDate}</p>
    </header>

    <article class="clearfix prose max-w-none">
      <slot />
    </article>
  </div>
</BaseLayout>
